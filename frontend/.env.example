# Copy this file to .env.local and fill in your values.
# All NEXT_PUBLIC_ vars are exposed to the browser — never put secrets here.

# ── Echo Contracts (deployed Sui Testnet) ────────────────────────────────────
# Get these from the deploy output or ask the team lead.
NEXT_PUBLIC_ECHO_PACKAGE_ID=
NEXT_PUBLIC_PROFILE_REGISTRY_ID=

# ── DeepBook Predict (Sui Testnet) ───────────────────────────────────────────
# These are fixed public addresses from mystenlabs docs — don't change them.
NEXT_PUBLIC_PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
NEXT_PUBLIC_PREDICT_OBJECT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
NEXT_PUBLIC_PREDICT_REGISTRY_ID=0x43af14fed5480c20ff77e2263d5f794c35b9fab7e2212903127062f4fe2a6e64

# ── dUSDC Coin Type ───────────────────────────────────────────────────────────
NEXT_PUBLIC_DUSDC_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC

# ── Endpoints ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_PREDICT_SERVER_URL=https://predict-server.testnet.mystenlabs.com
NEXT_PUBLIC_WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space
NEXT_PUBLIC_WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
